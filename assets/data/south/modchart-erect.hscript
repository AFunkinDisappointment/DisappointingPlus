	case 1216:
		FocusCamera({char: 0});
	case 1217:
		ZoomCamera({duration: 32, ease: 'expoOut', mode: 'stage'});
	case 1232:
		ZoomCamera({zoom: 1.1, duration: 32, ease: 'expoOut', mode: 'stage'});
	case 1248:
		ZoomCamera({duration: 32, ease: 'expoOut', mode: 'stage'});
	case 1264:
		ZoomCamera({zoom: 1.1, duration: 32, ease: 'expoOut', mode: 'stage'});
	case 1280:
		FocusCamera({char: 0});
	case 1281:
		ZoomCamera({duration: 32, ease: 'expoOut', mode: 'stage'});
	case 1296:
		ZoomCamera({zoom: 0.75, duration: 64, ease: 'sineInOut', mode: 'stage'});
    }
}
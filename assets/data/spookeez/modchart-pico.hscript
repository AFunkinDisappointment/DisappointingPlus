function start(song) {
    FocusCamera({char: 0});
}

function noteLoaded(note) {
    if (note.altNum > 0) {
	if (!note.mustPress || note.altNum == 1)
	    note.noteHit = 'cheer';
	else
	    note.noteHit = 'hey';
    }
}

function hey(note) {
    getHaxeActor('bf').playAnim('hey', true);
}

function cheer(note) {
    if (note.mustPress)
	getHaxeActor('bf').playAnim('cheer', true);
    else
	getHaxeActor('dad').playAnim('cheer', true);
}

function stepHit(step) {
    switch(step) {
	case 1:
		SetCameraBop({rate: 2, intensity: 0.8});
	case 63:
		SetCameraBop({rate: 2});
	case 64:
		FocusCamera({char: 1});
	case 96:
		FocusCamera({char: 0});
	case 128:
		FocusCamera({char: 1});
	case 160:
		FocusCamera({char: 0});
	case 178:
		ZoomCamera({zoom: 1.1, duration: 16, ease: 'expoOut', mode: 'stage'});
	case 188:
		ZoomCamera({duration: 16, ease: 'expoOut', mode: 'stage'});
	case 192:
		FocusCamera({char: 1});
	case 256:
		FocusCamera({char: 0});
	case 280:
		ZoomCamera({zoom: 1.05, duration: 16, ease: 'expoOut', mode: 'stage'});
	case 283:
		ZoomCamera({zoom: 1.1, duration: 16, ease: 'expoOut', mode: 'stage'});
	case 288:
		ZoomCamera({zoom: 1.15, duration: 16, ease: 'expoOut', mode: 'stage'});
	case 310:
		ZoomCamera({zoom: 1.1, duration: 16, ease: 'expoOut', mode: 'stage'});
	case 312:
		ZoomCamera({zoom: 1.05, duration: 16, ease: 'expoOut', mode: 'stage'});
	case 320:
		FocusCamera({char: 1});
	case 321:
		ZoomCamera({duration: 16, ease: 'expoOut', mode: 'stage'});
	case 352:
		FocusCamera({char: 0});
	case 384:
		FocusCamera({char: 1});
	case 416:
		FocusCamera({char: 0});
	case 434:
		ZoomCamera({zoom: 1.1, duration: 16, ease: 'expoOut', mode: 'stage'});
	case 444:
		ZoomCamera({duration: 16, ease: 'expoOut', mode: 'stage'});
	case 448:
		FocusCamera({char: 1});
	case 482:
		FocusCamera({char: 1, x: 300});
	case 483:
		ZoomCamera({zoom: 0.9, duration: 16, ease: 'expoOut', mode: 'stage'});
	case 512:
		FocusCamera({char: 0});
	case 513:
		ZoomCamera({duration: 16, ease: 'expoOut', mode: 'stage'});
	case 536:
		ZoomCamera({zoom: 1.05, duration: 16, ease: 'expoOut', mode: 'stage'});
	case 539:
		ZoomCamera({zoom: 1.1, duration: 16, ease: 'expoOut', mode: 'stage'});
	case 544:
		ZoomCamera({zoom: 1.15, duration: 16, ease: 'expoOut', mode: 'stage'});
	case 568:

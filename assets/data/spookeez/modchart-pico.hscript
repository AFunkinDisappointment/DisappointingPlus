	case 572:
		ZoomCamera({zoom: 1.05, duration: 16, ease: 'expoOut', mode: 'stage'});
	case 575:
		SetCameraBop({rate: 1, intensity: 1.1});
	case 576:
		FocusCamera({char: 1});
	case 577:
		ZoomCamera({duration: 16, ease: 'expoOut', mode: 'stage'});
	case 624:
		FocusCamera({char: 1, x: 300});
	case 625:
		ZoomCamera({zoom: 0.9, duration: 16, ease: 'expoOut', mode: 'stage'});
	case 640:
		FocusCamera({char: 0});
	case 641:
		ZoomCamera({duration: 16, ease: 'expoOut', mode: 'stage'});
	case 648:

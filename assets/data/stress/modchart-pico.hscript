var bloodyTankman;
function start(song) {
    FocusCamera({char: 1});

    bloodyTankman = addCharacter('tankman-bloody', 'dad');
    bloodyTankman.followCamX += 50;
}

function stepHit(step) {
    switch(step) {
	case 64:
		FocusCamera({char: 0});
	case 96:
		ZoomCamera({zoom: 1.1, duration: 32, ease: 'expoOut', mode: 'stage'});
	case 128:
		FocusCamera({char: 1});
		ZoomCamera({duration: 32, ease: 'expoOut', mode: 'stage'});
	case 192:
		FocusCamera({char: 0});
	case 210:
		ZoomCamera({zoom: 1.1, duration: 32, ease: 'expoOut', mode: 'stage'});
	case 224:
		ZoomCamera({duration: 32, ease: 'expoOut', mode: 'stage'});
	case 239:
		SetCameraBop({rate: 1, intensity: 1.2});
	case 242:
		ZoomCamera({zoom: 1.1, duration: 32, ease: 'expoOut', mode: 'stage'});
	case 255:
		SetCameraBop({rate: 1, intensity: 0.8});
	case 256:
		FocusCamera({char: 1, x: 320, y: -70});
	case 257:
		ZoomCamera({zoom: 0.9, duration: 32, ease: 'expoOut', mode: 'stage'});
	case 288:
		FocusCamera({char: 0});
		ZoomCamera({duration: 32, ease: 'expoOut', mode: 'stage'});
	case 320:
		FocusCamera({char: 1, x: 320, y: -70});
		ZoomCamera({zoom: 0.9, duration: 32, ease: 'expoOut', mode: 'stage'});
	case 352:
		ZoomCamera({zoom: 0.95, duration: 32, ease: 'expoOut', mode: 'stage'});
	case 367:
		SetCameraBop({rate: 1, intensity: 1.2});
	case 383:
		SetCameraBop({rate: 1, intensity: 0.4});
	case 384:
		FocusCamera({char: 1});
		ZoomCamera({duration: 32, ease: 'expoOut', mode: 'stage'});
	case 448:
		FocusCamera({char: 0});
	case 464:
		ZoomCamera({zoom: 1.05, duration: 32, ease: 'expoOut', mode: 'stage'});
	case 480:
		ZoomCamera({duration: 32, ease: 'expoOut', mode: 'stage'});
	case 495:
		SetCameraBop({rate: 1, intensity: 1.2});
	case 496:
		ZoomCamera({zoom: 1.1, duration: 32, ease: 'expoOut', mode: 'stage'});
	case 511:
		SetCameraBop({rate: 1, intensity: 0.5});

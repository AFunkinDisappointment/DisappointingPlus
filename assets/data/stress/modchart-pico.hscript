	case 639:
		SetCameraBop({rate: 2, intensity: 1.5});
	case 642:
		ZoomCamera({zoom: 0.95, duration: 16, ease: 'expoOut', mode: 'stage'});
	case 658:
		ZoomCamera({duration: 16, ease: 'expoOut', mode: 'stage'});

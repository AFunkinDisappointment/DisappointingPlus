function update(elapsed) {
    darkbf.playAnim(getHaxeActor("boyfriend").animation.curAnim.name, true, false, getHaxeActor("boyfriend").animation.curAnim.curFrame);
    darkgf.playAnim(getHaxeActor("gf").animation.curAnim.name, true, false, getHaxeActor("gf").animation.curAnim.curFrame);
    darkdad.playAnim(getHaxeActor("dad").animation.curAnim.name, true, false, getHaxeActor("dad").animation.curAnim.curFrame);
}